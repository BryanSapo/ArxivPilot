# Copy this file to ".env" and fill in your own values.
# Do NOT commit your real .env file — it contains secrets.

# API key for your LLM provider (e.g. OpenRouter).
# You an use any LLM provider, just make sure to change the env variable in the code.
OPENROUTER_API_KEY=your-api-key-here

# Model slug to use. Must support tool/function calling.
# Example (recommended): openai/gpt-4o-mini
MODEL=openai/gpt-4o-mini

# OpenAI-compatible base URL for the provider.
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1
